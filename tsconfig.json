{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["server.ts", "app.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}